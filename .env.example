# Twilio Configuration (SMS)
NEXT_PUBLIC_TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# SendGrid Configuration (Email)
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@logisticscompany.com
SENDGRID_FROM_NAME=Logistics Company

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Privacy & Compliance
NEXT_PUBLIC_COMPANY_EMAIL=privacy@logisticscompany.com
NEXT_PUBLIC_COMPANY_PHONE=+1-800-LOGISTICS
NEXT_PUBLIC_DATA_RETENTION_DAYS=90
